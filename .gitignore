# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# IDE
.idea
.vscode
.claude/

# Virtual environments
.venv

# Docker runtime files (ignore contents but allow .gitkeep exceptions)
docker/mount_runtime/**
!docker/mount_runtime/foil_serve/
!docker/mount_runtime/foil_serve/logs/
!docker/mount_runtime/foil_serve/logs/.gitkeep
